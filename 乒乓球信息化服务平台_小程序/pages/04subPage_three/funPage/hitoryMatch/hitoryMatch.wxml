<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-title">参赛历史</view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view 
      wx:for="{{filterOptions}}" 
      wx:key="value"
      class="filter-item {{selectedFilter === item.value ? 'active' : ''}}"
      bindtap="onSelectFilter"
      data-filter="{{item.value}}"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 参赛历史列表 -->
  <view class="contest-list">
    <view 
      wx:for="{{contestList}}" 
      wx:key="id"
      class="contest-item"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <!-- 比赛基本信息 -->
      <view class="contest-info">
        <view class="contest-header">
          <view class="contest-name">{{item.name}}</view>
          <view class="contest-status {{item.status}}">{{getStatusText(item.status)}}</view>
        </view>
        
        <view class="contest-meta">
          <view class="meta-item">
            <text class="meta-label">时间：</text>
            <text class="meta-value">{{item.time}}</text>
          </view>
          <view class="meta-item">
            <text class="meta-label">地点：</text>
            <text class="meta-value">{{item.location}}</text>
          </view>
        </view>

        <!-- 比赛成绩（已完成的比赛显示） -->
        <view wx:if="{{item.status === 'completed'}}" class="contest-result">
          <view class="result-item">
            <text class="result-label">成绩：</text>
            <text class="result-score">{{item.score}}</text>
          </view>
          <view class="result-item">
            <text class="result-label">排名：</text>
            <text class="result-rank">{{item.rank}}/{{item.total}}</text>
          </view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="contest-actions">
        <button 
          class="detail-btn"
          bindtap="goToDetail"
          data-id="{{item.id}}"
          catchtap="true"
        >
          查看详情
        </button>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && contestList.length === 0}}" class="empty-state">
    <text>暂无参赛记录</text>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{hasMore && !loading}}" class="load-more" bindtap="loadMore">
    <text>加载更多</text>
  </view>
</view>