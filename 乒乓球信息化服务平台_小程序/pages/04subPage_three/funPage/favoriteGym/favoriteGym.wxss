/* 全局样式 */
.container {
    background-color: #f7f8fa;
    min-height: 100vh;
    padding-bottom: 20px;
  }
  
  /* 页面头部 */
  .page-header {
    background: linear-gradient(135deg, #1aad19 0%, #147a13 100%);
    padding: 20px 15px;
    box-shadow: 0 2px 10px rgba(26, 173, 25, 0.1);
  }
  
  .header-title {
    font-size: 18px;
    font-weight: bold;
    color: white;
    text-align: center;
    letter-spacing: 1px;
  }
  
  /* 筛选栏 */
  .filter-scroll {
    background-color: white;
    padding: 10px 0;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
  }
  
  .filter-bar {
    display: flex;
    padding: 0 15px;
  }
  
  .filter-item {
    padding: 8px 18px;
    margin-right: 10px;
    background-color: #f5f5f5;
    border-radius: 20px;
    transition: all 0.3s ease;
  }
  
  .filter-item.active {
    background: linear-gradient(135deg, #1aad19 0%, #147a13 100%);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(26, 173, 25, 0.2);
  }
  
  .filter-text {
    font-size: 14px;
    color: #666;
    font-weight: 500;
  }
  
  .filter-item.active .filter-text {
    color: white;
  }
  
  /* 场馆列表 */
  .venue-list {
    padding: 15px;
  }
  
  .venue-item {
    background-color: white;
    border-radius: 16px;
    margin-bottom: 15px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    position: relative;
  }
  
  .venue-item-hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
  }
  
  /* 图片容器 */
  .image-container {
    position: relative;
    height: 220px;
    overflow: hidden;
  }
  
  .venue-image {
    width: 100%;
    height: 100%;
    transition: transform 0.3s ease;
  }
  
  .venue-item-hover .venue-image {
    transform: scale(1.05);
  }
  
  .category-tag {
    position: absolute;
    top: 15px;
    left: 15px;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: bold;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
  
  .category-tag.stadium {
    background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
    color: white;
  }
  
  .category-tag.swimming {
    background: linear-gradient(135deg, #722ed1 0%, #531dab 100%);
    color: white;
  }
  
  .category-tag.gym {
    background: linear-gradient(135deg, #ff9900 0%, #d46b08 100%);
    color: white;
  }
  
  .category-tag.badminton {
    background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
    color: white;
  }
  
  .category-tag.basketball {
    background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%);
    color: white;
  }
  
  .favorite-badge {
    position: absolute;
    top: 15px;
    right: 15px;
    width: 36px;
    height: 36px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
  
  .favorite-badge .icon-collect-filled {
    color: #ff9900;
    font-size: 18px;
  }
  
  /* 场馆信息 */
  .venue-info {
    padding: 20px;
  }
  
  .venue-header {
    margin-bottom: 12px;
  }
  
  .venue-name {
    font-size: 18px;
    font-weight: bold;
    color: #333;
    line-height: 1.4;
  }
  
  .rating-container {
    display: flex;
    align-items: center;
    margin-bottom: 10px;
  }
  
  .stars {
    display: flex;
    margin-right: 8px;
  }
  
  .star {
    color: #e8e8e8;
    font-size: 16px;
    margin-right: 2px;
  }
  
  .star.active {
    color: #ff9900;
  }
  
  .rating-text {
    font-size: 16px;
    font-weight: bold;
    color: #ff9900;
    margin-right: 5px;
  }
  
  .review-count {
    font-size: 12px;
    color: #999;
  }
  
  .address-container {
    display: flex;
    align-items: center;
    margin-bottom: 10px;
    font-size: 14px;
    color: #666;
  }
  
  .address-container .icon-location {
    color: #ff4d4f;
    font-size: 14px;
    margin-right: 6px;
  }
  
  .address-text {
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }
  
  .price-container {
    display: flex;
    align-items: center;
    margin-bottom: 15px;
  }
  
  .price-prefix {
    font-size: 14px;
    color: #666;
  }
  
  .price-value {
    font-size: 20px;
    font-weight: bold;
    color: #ff4444;
    margin: 0 5px;
  }
  
  .price-suffix {
    font-size: 14px;
    color: #666;
  }
  
  .features-container {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  
  .feature-tag {
    padding: 4px 12px;
    background-color: #f5f5f5;
    border-radius: 20px;
    font-size: 12px;
    color: #666;
    border: 1px solid #e8e8e8;
    transition: all 0.2s ease;
  }
  
  .feature-tag:hover {
    background-color: #e8e8e8;
  }
  
  .feature-text {
    line-height: 1.5;
  }
  
  /* 操作按钮 */
  .action-buttons {
    display: flex;
    padding: 0 20px 20px 20px;
    gap: 12px;
  }
  
  .navigate-btn, .collect-btn {
    flex: 1;
    padding: 14px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    border: none;
  }
  
  .navigate-btn {
    background: linear-gradient(135deg, #1aad19 0%, #147a13 100%);
    color: white;
  }
  
  .navigate-btn-hover {
    background: linear-gradient(135deg, #147a13 0%, #0f5a0f 100%);
    transform: scale(0.98);
  }
  
  .collect-btn {
    background-color: white;
    color: #ff9900;
    border: 1px solid #ff9900;
  }
  
  .collect-btn-hover {
    background-color: #fff7e6;
    transform: scale(0.98);
  }
  
  .navigate-btn .icon-navigate, .collect-btn .icon-collect-filled {
    margin-right: 6px;
    font-size: 16px;
  }
  
  .btn-text {
    font-size: 14px;
    font-weight: 500;
  }
  
  /* 状态样式 */
  .loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 60px 0;
  }
  
  .loading-spinner {
    width: 32px;
    height: 32px;
    border: 3px solid #f3f3f3;
    border-top: 3px solid #1aad19;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 15px;
  }
  
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  
  .loading-text {
    font-size: 16px;
    color: #999;
  }
  
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 60px 20px;
    text-align: center;
  }
  
  .empty-icon {
    width: 100px;
    height: 100px;
    background-color: #f5f5f5;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }
  
  .empty-icon .icon-empty-collection {
    font-size: 48px;
    color: #ccc;
  }
  
  .empty-title {
    font-size: 18px;
    font-weight: bold;
    color: #333;
    margin-bottom: 8px;
  }
  
  .empty-subtitle {
    font-size: 14px;
    color: #999;
    margin-bottom: 30px;
  }
  
  .go-browse-btn {
    padding: 14px 32px;
    background: linear-gradient(135deg, #1aad19 0%, #147a13 100%);
    color: white;
    border: none;
    border-radius: 25px;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.3s ease;
  }
  
  .go-browse-btn-hover {
    background: linear-gradient(135deg, #147a13 0%, #0f5a0f 100%);
    transform: scale(0.98);
  }
  
  .load-more {
    text-align: center;
    padding: 20px 0;
    color: #1aad19;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: color 0.3s ease;
  }
  
  .load-more:active {
    color: #147a13;
  }
  
  /* 响应式设计 */
  @media (max-width: 375px) {
    .venue-info {
      padding: 15px;
    }
    
    .venue-name {
      font-size: 16px;
    }
    
    .action-buttons {
      padding: 0 15px 15px 15px;
    }
    
    .navigate-btn, .collect-btn {
      padding: 12px;
      font-size: 13px;
    }
  }