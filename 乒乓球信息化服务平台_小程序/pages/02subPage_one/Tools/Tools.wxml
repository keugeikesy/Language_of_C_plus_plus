<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input 
      class="search-input" 
      placeholder="搜索器材..." 
      bindinput="onSearchInput"
      value="{{searchKeyword}}"
    />
    <button 
      class="search-btn" 
      bindtap="onSearch"
    >
      搜索
    </button>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <scroll-view 
      class="filter-scroll" 
      scroll-x="true"
    >
      <view 
        class="filter-item {{selectedBrand === '' ? 'active' : ''}}"
        bindtap="onSelectBrand"
        data-brand=""
      >
        全部
      </view>
      <view 
        wx:for="{{brands}}" 
        wx:key="id"
        class="filter-item {{selectedBrand === item.name ? 'active' : ''}}"
        bindtap="onSelectBrand"
        data-brand="{{item.name}}"
      >
        {{item.name}}
      </view>
    </scroll-view>
  </view>

  <!-- 器材列表 -->
  <view class="equipment-list">
    <view 
      wx:for="{{equipmentList}}" 
      wx:key="id"
      class="equipment-item"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <image 
        class="equipment-image" 
        src="{{item.image}}"
        mode="aspectFill"
      />
      <view class="equipment-info">
        <view class="equipment-name">{{item.name}}</view>
        <view class="equipment-brand">{{item.brand}}</view>
        <view class="equipment-price">¥{{item.price}}</view>
      </view>
      <view class="equipment-actions">
        <button 
          class="collect-btn {{item.isCollected ? 'collected' : ''}}"
          bindtap="onCollect"
          data-id="{{item.id}}"
          catchtap="true"
        >
          {{item.isCollected ? '已收藏' : '收藏'}}
        </button>
        <button 
          class="buy-btn"
          bindtap="onBuy"
          data-id="{{item.id}}"
          catchtap="true"
        >
          购买
        </button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{equipmentList.length === 0}}" class="empty-state">
    <text>暂无器材数据</text>
  </view>
</view>