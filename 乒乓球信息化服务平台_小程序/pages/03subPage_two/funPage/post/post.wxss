/* 全局样式 */
.post-container {
    min-height: 100vh;
    background-color: #f5f5f5;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  }
  
  /* 顶部导航栏 */
  .post-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: white;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .header-left {
    display: flex;
    align-items: center;
  }
  
  .header-title {
    font-size: 36rpx;
    font-weight: 600;
    color: #333;
    margin-left: 135rpx;
  }
  
  .publish-btn {
    background-color: #1aad19;
    color: white;
    border-radius: 20rpx;
    padding: 15rpx 25rpx;
    font-size: 26rpx;
  }
  
  .publish-btn:disabled {
    background-color: #ccc;
    color: #999;
  }
  
  /* 发布表单 */
  .post-form {
    padding: 30rpx;
  }
  
  .form-section {
    background-color: white;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
  }
  
  .section-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 20rpx;
  }
  
  /* 选择分类 */
  .picker-select {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20rpx;
    background-color: #f5f5f5;
    border-radius: 12rpx;
    font-size: 28rpx;
    color: #333;
  }
  
  .picker-arrow {
    font-size: 24rpx;
    color: #999;
  }
  
  /* 标题输入 */
  .title-input {
    width: 100%;
    padding: 20rpx;
    font-size: 28rpx;
    border: 1rpx solid #f0f0f0;
    border-radius: 12rpx;
    margin-bottom: 15rpx;
  }
  
  .title-count {
    font-size: 24rpx;
    color: #999;
    text-align: right;
  }
  
  /* 内容输入 */
  .content-textarea {
    width: 100%;
    padding: 20rpx;
    font-size: 28rpx;
    border: 1rpx solid #f0f0f0;
    border-radius: 12rpx;
    margin-bottom: 15rpx;
    min-height: 200rpx;
  }
  
  .content-count {
    font-size: 24rpx;
    color: #999;
    text-align: right;
  }
  
  /* 图片上传 */
  .image-uploader {
    margin-top: 20rpx;
  }
  
  .image-list {
    display: flex;
    flex-wrap: wrap;
    gap: 15rpx;
    margin-bottom: 15rpx;
  }
  
  .image-item {
    position: relative;
    width: 200rpx;
    height: 200rpx;
  }
  
  .image-preview {
    width: 100%;
    height: 100%;
    border-radius: 12rpx;
    object-fit: cover;
  }
  
  .image-delete {
    position: absolute;
    top: -10rpx;
    right: -10rpx;
    width: 40rpx;
    height: 40rpx;
    background-color: #ff4757;
    color: white;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 24rpx;
  }
  
  .add-image-btn {
    width: 200rpx;
    height: 200rpx;
    border: 2rpx dashed #ccc;
    border-radius: 12rpx;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background-color: #fafafa;
  }
  
  .add-icon {
    font-size: 48rpx;
    color: #ccc;
    margin-bottom: 10rpx;
  }
  
  .add-text {
    font-size: 24rpx;
    color: #999;
  }
  
  .image-tip {
    font-size: 24rpx;
    color: #999;
  }
  
  /* 标签选择 */
  .tag-selector {
    display: flex;
    flex-wrap: wrap;
    gap: 15rpx;
    margin-bottom: 20rpx;
  }