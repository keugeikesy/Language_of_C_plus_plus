<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-title">我的收藏</view>
  </view>

  <!-- 筛选栏 -->
  <scroll-view class="filter-scroll" scroll-x="true">
    <view class="filter-bar">
      <view 
        wx:for="{{filterOptions}}" 
        wx:key="value"
        class="filter-item {{selectedFilter === item.value ? 'active' : ''}}"
        bindtap="onSelectFilter"
        data-filter="{{item.value}}"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <!-- 帖子列表 -->
  <view class="post-list">
    <view 
      wx:for="{{postList}}" 
      wx:key="postId"
      class="post-item"
      bindtap="goToDetail"
      data-id="{{item.postId}}"
    >
      <!-- 帖子头部 -->
      <view class="post-header">
        <image 
          class="avatar" 
          src="{{item.author.avatar}}"
          mode="aspectFill"
        />
        <view class="author-info">
          <view class="author-name">{{item.author.name}}</view>
          <view class="post-time">{{item.createTime}}</view>
        </view>
        <view class="category-tag {{item.category}}">{{getCategoryText(item.category)}}</view>
      </view>

      <!-- 帖子内容 -->
      <view class="post-content">
        <view class="post-title">{{item.title}}</view>
        <view class="post-summary">{{item.summary}}</view>
        
        <!-- 帖子图片 -->
        <view wx:if="{{item.images.length > 0}}" class="post-images">
          <image 
            wx:for="{{item.images}}" 
            wx:key="index"
            class="post-image" 
            src="{{item}}"
            mode="aspectFill"
          />
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="post-actions">
        <view class="action-item">
          <text class="iconfont icon-like"></text>
          <text class="action-text">{{item.likeCount}}</text>
        </view>
        <view class="action-item">
          <text class="iconfont icon-comment"></text>
          <text class="action-text">{{item.commentCount}}</text>
        </view>
        <view class="action-item">
          <text class="iconfont icon-share"></text>
          <text class="action-text">分享</text>
        </view>
        <view class="action-item collect-btn" bindtap="onCancelCollect" data-id="{{item.postId}}" catchtap="true">
          <text class="iconfont icon-collect-filled"></text>
          <text class="action-text">取消收藏</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && postList.length === 0}}" class="empty-state">
    <image 
      class="empty-image" 
      src="https://example.com/empty-collection.png"
      mode="aspectFit"
    />
    <text class="empty-text">暂无收藏的帖子</text>
    <button class="go-browse-btn" bindtap="goBrowse">去浏览</button>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{hasMore && !loading}}" class="load-more" bindtap="loadMore">
    <text>加载更多</text>
  </view>
</view>