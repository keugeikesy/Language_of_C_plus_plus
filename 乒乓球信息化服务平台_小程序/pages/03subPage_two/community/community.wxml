<view class="forum-container">
  <!-- 顶部导航栏 -->
  <view class="forum-header">
    <view class="header-title">乒乓论坛</view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <input 
      class="search-input" 
      placeholder="搜索帖子、用户、话题..." 
      bindinput="onSearchInput"
      bindconfirm="onSearchConfirm"
    />
    <button class="search-btn" bindtap="onSearch">搜索</button>
  </view>

  <!-- 分类标签 -->
  <view class="category-tabs">
    <scroll-view scroll-x="true" class="tab-scroll">
      <view 
        class="tab-item {{currentCategory === item.id ? 'active' : ''}}" 
        wx:for="{{categories}}" 
        wx:key="id"
        bindtap="switchCategory"
        data-category="{{item.id}}"
      >
        {{item.name}}
      </view>
    </scroll-view>
  </view>

  <!-- 帖子列表 -->
  <view class="post-list">
    <view 
      class="post-item" 
      wx:for="{{postList}}" 
      wx:key="id"
      bindtap="navigateToDetail"
      data-id="{{item.id}}"
    >
      <!-- 作者信息 -->
      <view class="post-author">
        <image class="author-avatar" src="{{item.author.avatar}}" mode="aspectFill"></image>
        <view class="author-info">
          <view class="author-name">{{item.author.name}}</view>
          <view class="post-time">{{item.time}}</view>
        </view>
      </view>

      <!-- 帖子内容 -->
      <view class="post-content">
        <view class="post-title">{{item.title}}</view>
        <view class="post-desc">{{item.content}}</view>
        
        <!-- 帖子图片 -->
        <view class="post-images" wx:if="{{item.images.length > 0}}">
          <image 
            wx:for="{{item.images}}" 
            wx:key="index"
            class="post-image" 
            src="{{item}}" 
            mode="aspectFill"
          ></image>
        </view>
      </view>

      <!-- 帖子统计 -->
      <view class="post-stats">
        <view class="stat-item" bindtap="onLike" data-id="{{item.id}}">
          <text class="like-icon {{item.liked ? 'liked' : ''}}">❤️</text>
          <text class="stat-text">{{item.likeCount}}</text>
        </view>
        <view class="stat-item" bindtap="onComment" data-id="{{item.id}}">
          <text class="comment-icon">💬</text>
          <text class="stat-text">{{item.commentCount}}</text>
        </view>
        <view class="stat-item" bindtap="onCollect" data-id="{{item.id}}">
          <text class="collect-icon {{item.collected ? 'collected' : ''}}">⭐</text>
          <text class="stat-text">{{item.collectCount}}</text>
        </view>
        <view class="stat-item" bindtap="sharePost" data-id="{{item.id}}">
          <text class="share-icon">📤</text>
          <text class="stat-text">分享</text>
        </view>
      </view>

      <!-- 分割线 -->
      <view class="divider"></view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <text class="loading-icon">🔄</text>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空数据提示 -->
  <view wx:if="{{!loading && postList.length === 0}}" class="empty">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无帖子</text>
    <button class="empty-btn" bindtap="navigateToPublish">发布第一条帖子</button>
  </view>

  <!-- 底部发布按钮 -->
  <view class="bottom-publish">
    <button class="publish-fab" bindtap="navigateToPublish">
      <text class="fab">✏️发布</text>
    </button>
  </view>
</view>