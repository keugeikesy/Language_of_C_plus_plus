<view class="profile-container">
  <!-- 用户信息头部 -->
  <view class="profile-header">
    <view class="user-info">
      <image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
      <view class="user-details">
        <view class="user-name">{{userInfo.name}}</view>
        <view class="user-signature">{{userInfo.signature}}</view>
      </view>
      <button class="edit-btn" bindtap="editProfile">编辑资料</button>
    </view>
    <view class="user-stats">
      <view class="stat-item" bindtap="showStats('events')">
        <view class="stat-value">{{userInfo.eventCount}}</view>
        <view class="stat-label">参赛次数</view>
      </view>
      <view class="stat-item" bindtap="showStats('orders')">
        <view class="stat-value">{{userInfo.orderCount}}</view>
        <view class="stat-label">订单数量</view>
      </view>
      <view class="stat-item" bindtap="showStats('favorites')">
        <view class="stat-value">{{userInfo.favoriteCount}}</view>
        <view class="stat-label">收藏数量</view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="profile-menu">
    <!-- 赛事记录 -->
    <view class="menu-section">
      <view class="menu-title">赛事记录</view>
      <view class="menu-items">
        <view class="menu-item" bindtap="navigateTo">
          <view class="menu-icon">🏆</view>
          <view class="menu-text">参赛历史</view>
          <view class="menu-arrow">></view>
        </view>
      </view>
    </view>

    <!-- 器材订单 -->
    <view class="menu-section">
      <view class="menu-title">器材订单</view>
      <view class="menu-items">
        <view class="menu-item" bindtap="navigateTo('order-all')">
          <view class="menu-icon">📦</view>
          <view class="menu-text">全部订单</view>
          <view class="menu-arrow">></view>
        </view>
      </view>
    </view>

    <!-- 帖子收藏 -->
    <view class="menu-section">
      <view class="menu-title">我的收藏</view>
      <view class="menu-items">
        <view class="menu-item" bindtap="navigateTo('favorite-posts')">
          <view class="menu-icon">❤️</view>
          <view class="menu-text">收藏帖子</view>
          <view class="menu-arrow">></view>
        </view>
        <view class="menu-item" bindtap="navigateTo('favorite-venues')">
          <view class="menu-icon">🏟️</view>
          <view class="menu-text">收藏场馆</view>
          <view class="menu-arrow">></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>