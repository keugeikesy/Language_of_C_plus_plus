/* 自定义背景样式 */
.globalSearch{
    display: flex; 
    flex-direction: row; 
    background-color:  #FF0000;
    width: 750rpx;
    height: 90rpx;
}
.cityName{
    font-size: 26rpx;
    font-weight: bold;
    border-radius: 25rpx;
    color: green;
}
/* 搜索框样式 */
.search{
    background-color: #ffffff;
    border-radius: 50rpx;
    width: 550rpx;
    height: 40rpx;
    text-align: center;
    padding: 10rpx 10rpx 5rpx 5rpx;
    margin-top: 20rpx;
    margin-bottom: 10rpx;
    margin-left: 25rpx;
    font-weight: bold;
    font-size: 26rpx;
}
/* 功能区域 */
/* 全局样式 */
.sports-container {
    min-height: 100vh;
    background-color: #f5f5f5;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  }
  
  /* 导航栏样式 */
  .nav-container {
    background-color: white;
    border-bottom: 1rpx solid #e5e5e5;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  
  .nav-scroll {
    white-space: nowrap;
    padding: 0 30rpx;
  }
  
  .nav-item {
    display: inline-block;
    padding: 30rpx 40rpx;
    text-align: center;
    position: relative;
    transition: all 0.3s ease;
  }
  
  .nav-text {
    font-size: 32rpx;
    color: #666;
    font-weight: 500;
    transition: color 0.3s ease;
  }
  
  .nav-item.active .nav-text {
    color: #1aad19;
    font-weight: 600;
  }
  
  .nav-underline {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60rpx;
    height: 6rpx;
    background-color: #1aad19;
    border-radius: 3rpx;
    transition: all 0.3s ease;
  }
  
  /* 内容区域样式 */
  .content-container {
    padding: 20rpx;
  }
  
  .tab-content {
    animation: fadeIn 0.3s ease;
  }
  
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20rpx);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .section-title {
    font-size: 36rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 30rpx;
    padding-left: 10rpx;
    border-left: 6rpx solid #1aad19;
  }
  
  /* 场馆列表样式 */
  .venue-list {
    background-color: white;
    border-radius: 16rpx;
    overflow: hidden;
  }
  
  .venue-item {
    display: flex;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
    transition: background-color 0.3s ease;
  }
  
  .venue-item:last-child {
    border-bottom: none;
  }
  
  .venue-item:active {
    background-color: #f5f5f5;
  }
  
  .venue-image {
    width: 160rpx;
    height: 160rpx;
    border-radius: 12rpx;
    margin-right: 30rpx;
  }
  
  .venue-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  
  .venue-name {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 10rpx;
  }
  
  .venue-address {
    font-size: 26rpx;
    color: #666;
    margin-bottom: 15rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  
  .venue-meta {
    display: flex;
    justify-content: space-between;
    font-size: 24rpx;
    color: #999;
  }
  
  /* 赛事列表样式 */
  .event-list {
    background-color: white;
    border-radius: 16rpx;
    overflow: hidden;
  }
  
  .event-item {
    display: flex;
    align-items: center;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
    transition: background-color 0.3s ease;
  }
  
  .event-item:last-child {
    border-bottom: none;
  }
  
  .event-item:active {
    background-color: #f5f5f5;
  }
  
  .event-date {
    width: 120rpx;
    height: 120rpx;
    background-color: #f0f9eb;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    margin-right: 30rpx;
  }
  
  .event-month {
    font-size: 24rpx;
    color: #1aad19;
    font-weight: 600;
  }
  
  .event-day {
    font-size: 36rpx;
    color: #1aad19;
    font-weight: 700;
    margin-top: 5rpx;
  }
  
  .event-info {
    flex: 1;
  }
  
  .event-name {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 10rpx;
  }
  
  .event-time, .event-location {
    font-size: 26rpx;
    color: #666;
    margin-bottom: 8rpx;
  }
  
  .event-status {
    padding: 10rpx 20rpx;
    border-radius: 20rpx;
    font-size: 24rpx;
    font-weight: 500;
  }
  
  .status-active {
    background-color: #f0f9eb;
    color: #1aad19;
  }
  
  .status-ended {
    background-color: #f5f5f5;
    color: #999;
  }
  
  /* 课程列表样式 */
  .course-list {
    background-color: white;
    border-radius: 16rpx;
    overflow: hidden;
  }
  
  .course-item {
    display: flex;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
    transition: background-color 0.3s ease;
  }
  
  .course-item:last-child {
    border-bottom: none;
  }
  
  .course-item:active {
    background-color: #f5f5f5;
  }
  
  .course-image {
    width: 160rpx;
    height: 160rpx;
    border-radius: 12rpx;
    margin-right: 30rpx;
  }
  
  .course-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  
  .course-name {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 10rpx;
  }
  
  .course-teacher {
    font-size: 26rpx;
    color: #666;
    margin-bottom: 15rpx;
  }
  
  .course-meta {
    display: flex;
    justify-content: space-between;
    font-size: 24rpx;
    color: #999;
  }
  
  /* 教练列表样式 */
  .coach-list {
    background-color: white;
    border-radius: 16rpx;
    overflow: hidden;
  }
  
  .coach-item {
    display: flex;
    align-items: center;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
    transition: background-color 0.3s ease;
  }
  
  .coach-item:last-child {
    border-bottom: none;
  }
  
  .coach-item:active {
    background-color: #f5f5f5;
  }
  
  .coach-avatar {
    width: 120rpx;
    height: 120rpx;
    border-radius: 50%;
    margin-right: 30rpx;
  }
  
  .coach-info {
    flex: 1;
  }
  
  .coach-name {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 10rpx;
  }
  
  .coach-specialty {
    font-size: 26rpx;
    color: #666;
    margin-bottom: 15rpx;
  }
  
  .coach-meta {
    display: flex;
    justify-content: space-between;
    font-size: 24rpx;
    color: #999;
  }
  
  .coach-btn {
    background-color: #1aad19;
    color: white;
    border-radius: 20rpx;
    padding: 15rpx 30rpx;
    font-size: 26rpx;
  }
/* 轮播图区域样式 */
.swiper-container {
    margin: 20rpx;
    border-radius: 16rpx;
    overflow: hidden;
    background-color: white;
  }
.swiper-image{
    width: 750rpx;
}