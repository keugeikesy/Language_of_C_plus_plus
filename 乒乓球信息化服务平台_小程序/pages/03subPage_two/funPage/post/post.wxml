<view class="post-container">
  <!-- 顶部导航栏 -->
  <view class="post-header">
    <view class="header-left" bindtap="goBack">
    </view>
    <text class="header-title">发布帖子</text>
    <view class="header-right">
      <button class="publish-btn" bindtap="publishPost" disabled="{{!canPublish}}">发布</button>
    </view>
  </view>

  <!-- 发布表单 -->
  <view class="post-form">
    <!-- 选择分类 -->
    <view class="form-section">
      <view class="section-title">选择分类</view>
      <picker 
        range="{{categories}}" 
        range-key="name" 
        value="{{selectedCategoryIndex}}" 
        bindchange="onCategoryChange"
      >
        <view class="picker-select">
          <text>{{categories[selectedCategoryIndex].name}}</text>
          <text class="picker-arrow">></text>
        </view>
      </picker>
    </view>

    <!-- 标题输入 -->
    <view class="form-section">
      <view class="section-title">帖子标题</view>
      <input 
        class="title-input" 
        placeholder="请输入帖子标题（最多50字）" 
        maxlength="50"
        bindinput="onTitleInput"
        value="{{postTitle}}"
      />
      <view class="title-count">{{postTitle.length}}/50</view>
    </view>

    <!-- 内容输入 -->
    <view class="form-section">
      <view class="section-title">帖子内容</view>
      <textarea 
        class="content-textarea" 
        placeholder="请输入帖子内容（最多1000字）" 
        maxlength="1000"
        bindinput="onContentInput"
        value="{{postContent}}"
        auto-height
      />
      <view class="content-count">{{postContent.length}}/1000</view>
    </view>

    <!-- 图片上传 -->
    <view class="form-section">
      <view class="section-title">上传图片</view>
      <view class="image-uploader">
        <view class="image-list">
          <view 
            class="image-item" 
            wx:for="{{uploadedImages}}" 
            wx:key="index"
            bindtap="previewImage"
            data-index="{{index}}"
          >
            <image class="image-preview" src="{{item}}" mode="aspectFill"></image>
            <view class="image-delete" bindtap="deleteImage" data-index="{{index}}" catchtap="true">
              <text class="delete-icon">×</text>
            </view>
          </view>
          
          <!-- 添加图片按钮 -->
          <view 
            class="add-image-btn" 
            wx:if="{{uploadedImages.length < 9}}"
            bindtap="chooseImage"
          >
            <text class="add-icon">+</text>
            <text class="add-text">添加图片</text>
          </view>
        </view>
        <view class="image-tip">最多可上传9张图片</view>
      </view>
    </view>

    <!-- 标签选择 -->
    <view class="form-section">
      <view class="section-title">添加标签</view>
      <view class="tag-selector">
        <view 
          class="tag-item {{selectedTags.includes(item) ? 'selected' : ''}}" 
          wx:for="{{tags}}" 
          wx:key="item"
          bindtap="toggleTag"
          data-tag="{{item}}"
        >
          {{item}}
        </view>
      </view>
      <input 
        class="custom-tag-input" 
        placeholder="输入自定义标签，按回车添加" 
        bindconfirm="addCustomTag"
      />
    </view>
  </view>
</view>