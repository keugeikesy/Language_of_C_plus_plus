/* 全局样式 */
.forum-container {
    min-height: 100vh;
    background-color: #f5f5f5;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  }
  
  /* 顶部导航栏 */
  .forum-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: white;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .header-title {
    font-size: 36rpx;
    font-weight: 600;
    color: #333;
  }
  
  .publish-btn {
    background-color: #1aad19;
    color: white;
    border-radius: 20rpx;
    padding: 15rpx 25rpx;
    font-size: 26rpx;
  }
  
  /* 搜索栏 */
  .search-bar {
    display: flex;
    align-items: center;
    background-color: white;
    padding: 20rpx 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .search-input {
    flex: 1;
    background-color: #f5f5f5;
    border-radius: 20rpx;
    padding: 20rpx;
    font-size: 28rpx;
    margin-right: 20rpx;
  }
  
  .search-btn {
    background-color: #1aad19;
    color: white;
    border-radius: 20rpx;
    padding: 20rpx 30rpx;
    font-size: 26rpx;
  }
  
  /* 分类标签 */
  .category-tabs {
    background-color: white;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .tab-scroll {
    white-space: nowrap;
    padding: 20rpx 30rpx;
  }
  
  .tab-item {
    display: inline-block;
    padding: 15rpx 25rpx;
    margin-right: 20rpx;
    font-size: 28rpx;
    color: #666;
    border-radius: 20rpx;
    transition: all 0.3s ease;
  }
  
  .tab-item.active {
    background-color: #1aad19;
    color: white;
  }
  
  /* 帖子列表 */
  .post-list {
    padding: 20rpx;
  }
  
  .post-item {
    background-color: white;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    transition: background-color 0.3s ease;
  }
  
  .post-item:active {
    background-color: #f5f5f5;
  }
  
  /* 作者信息 */
  .post-author {
    display: flex;
    align-items: center;
    margin-bottom: 20rpx;
  }
  
  .author-avatar {
    width: 80rpx;
    height: 80rpx;
    border-radius: 50%;
    margin-right: 20rpx;
  }
  
  .author-info {
    flex: 1;
  }
  
  .author-name {
    font-size: 30rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 5rpx;
  }
  
  .post-time {
    font-size: 24rpx;
    color: #999;
  }
  
  /* 帖子内容 */
  .post-content {
    margin-bottom: 20rpx;
  }
  
  .post-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 15rpx;
    line-height: 1.4;
  }
  
  .post-desc {
    font-size: 28rpx;
    color: #666;
    line-height: 1.5;
    margin-bottom: 20rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }
  
  /* 帖子图片 */
  .post-images {
    display: flex;
    flex-wrap: wrap;
    gap: 15rpx;
  }
  
  .post-image {
    width: 200rpx;
    height: 200rpx;
    border-radius: 12rpx;
    object-fit: cover;
  }
  
  /* 帖子统计 */
  .post-stats {
    display: flex;
    justify-content: space-around;
    padding-top: 20rpx;
    border-top: 1rpx solid #f0f0f0;
  }
  
  .stat-item {
    display: flex;
    align-items: center;
    padding: 10rpx;
    border-radius: 12rpx;
    transition: background-color 0.3s ease;
  }
  
  .stat-item:active {
    background-color: #f5f5f5;
  }
  
  .like-icon, .comment-icon, .collect-icon, .share-icon {
    font-size: 32rpx;
    margin-right: 10rpx;
  }
  
  .like-icon.liked {
    color: #ff4757;
  }
  
  .collect-icon.collected {
    color: #ffa502;
  }
  
  .stat-text {
    font-size: 26rpx;
    color: #666;
  }
  
  /* 分割线 */
  .divider {
    height: 1rpx;
    background-color: #f0f0f0;
    margin-top: 20rpx;
  }
  
  /* 加载状态 */
  .loading {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 40rpx 0;
    color: #999;
    font-size: 28rpx;
  }
  
  .loading-icon {
    margin-right: 20rpx;
    animation: loading 1s infinite linear;
  }
  
  @keyframes loading {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  
  /* 空数据提示 */
  .empty {
    text-align: center;
    padding: 100rpx 0;
    color: #999;
    font-size: 28rpx;
  }
  
  .empty-icon {
    font-size: 80rpx;
    margin-bottom: 20rpx;
    color: #ccc;
  }
  
  .empty-btn {
    margin-top: 30rpx;
    background-color: #1aad19;
    color: white;
    border-radius: 20rpx;
    padding: 20rpx 40rpx;
    font-size: 28rpx;
  }
  
  /* 底部发布按钮 */
  .bottom-publish {
    position: fixed;
    bottom: 30rpx;
    right: 30rpx;
    z-index: 100;
  }
  
  .publish-fab {
    background-color: #f1442d;
    color: white;
    border-radius: 50%;
    width: 120rpx;
    height: 120rpx;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  }
  
  .fab {
    font-size: 20rpx;
    font-weight:600;
    color: #000;
  }