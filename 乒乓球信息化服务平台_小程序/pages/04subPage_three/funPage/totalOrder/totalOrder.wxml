<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-title">全部订单</view>
  </view>

  <!-- 筛选栏 -->
  <scroll-view class="filter-scroll" scroll-x="true">
    <view class="filter-bar">
      <view 
        wx:for="{{filterOptions}}" 
        wx:key="value"
        class="filter-item {{selectedFilter === item.value ? 'active' : ''}}"
        bindtap="onSelectFilter"
        data-filter="{{item.value}}"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view 
      wx:for="{{orderList}}" 
      wx:key="orderId"
      class="order-item"
    >
      <!-- 订单头部 -->
      <view class="order-header">
        <view class="order-info">
          <view class="order-number">订单编号：{{item.orderId}}</view>
          <view class="order-time">{{item.createTime}}</view>
        </view>
        <view class="order-status {{item.status}}">{{getStatusText(item.status)}}</view>
      </view>

      <!-- 商品列表 -->
      <view class="product-list">
        <view 
          wx:for="{{item.products}}" 
          wx:for-item="product"
          wx:key="productId"
          class="product-item"
          bindtap="goToProductDetail"
          data-product-id="{{product.productId}}"
        >
          <image 
            class="product-image" 
            src="{{product.image}}"
            mode="aspectFill"
          />
          <view class="product-info">
            <view class="product-name">{{product.name}}</view>
            <view class="product-spec">{{product.spec}}</view>
            <view class="product-price">¥{{product.price}}</view>
          </view>
          <view class="product-quantity">x{{product.quantity}}</view>
        </view>
      </view>

      <!-- 订单金额 -->
      <view class="order-amount">
        <view class="amount-label">订单总价：</view>
        <view class="amount-value">¥{{item.totalAmount}}</view>
      </view>

      <!-- 操作按钮 -->
      <view class="order-actions">
        <view wx:if="{{item.status === 'pending_payment'}}">
          <button 
            class="cancel-btn"
            bindtap="cancelOrder"
            data-order-id="{{item.orderId}}"
          >
            取消订单
          </button>
          <button 
            class="pay-btn"
            bindtap="payOrder"
            data-order-id="{{item.orderId}}"
          >
            立即支付
          </button>
        </view>
        <view wx:elif="{{item.status === 'pending_delivery'}}">
          <button 
            class="remind-btn"
            bindtap="remindDelivery"
            data-order-id="{{item.orderId}}"
          >
            提醒发货
          </button>
        </view>
        <view wx:elif="{{item.status === 'pending_receipt'}}">
          <button 
            class="receive-btn"
            bindtap="confirmReceipt"
            data-order-id="{{item.orderId}}"
          >
            确认收货
          </button>
        </view>
        <view wx:elif="{{item.status === 'completed'}}">
          <button 
            class="review-btn"
            bindtap="goToReview"
            data-order-id="{{item.orderId}}"
          >
            去评价
          </button>
          <button 
            class="buy-again-btn"
            bindtap="buyAgain"
            data-order-id="{{item.orderId}}"
          >
            再次购买
          </button>
        </view>
        <view wx:elif="{{item.status === 'cancelled'}}">
          <button 
            class="buy-again-btn"
            bindtap="buyAgain"
            data-order-id="{{item.orderId}}"
          >
            再次购买
          </button>
        </view>
        
        <button 
          class="detail-btn"
          bindtap="goToDetail"
          data-order-id="{{item.orderId}}"
        >
          订单详情
        </button>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && orderList.length === 0}}" class="empty-state">
    <image 
      class="empty-image" 
      src="https://example.com/empty-order.png"
      mode="aspectFit"
    />
    <text class="empty-text">暂无订单</text>
    <button class="go-shopping-btn" bindtap="goShopping">去购物</button>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{hasMore && !loading}}" class="load-more" bindtap="loadMore">
    <text>加载更多</text>
  </view>
</view>