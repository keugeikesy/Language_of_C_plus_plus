<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-title">收藏场馆</view>
  </view>

  <!-- 筛选栏 -->
  <scroll-view class="filter-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
    <view class="filter-bar">
      <view 
        wx:for="{{filterOptions}}" 
        wx:key="value"
        class="filter-item {{selectedFilter === item.value ? 'active' : ''}}"
        bindtap="onSelectFilter"
        data-filter="{{item.value}}"
      >
        <text class="filter-text">{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 场馆列表 -->
  <view class="venue-list">
    <view 
      wx:for="{{venueList}}" 
      wx:key="venueId"
      class="venue-item"
      bindtap="goToDetail"
      data-id="{{item.venueId}}"
      hover-class="venue-item-hover"
    >
      <!-- 场馆图片容器 -->
      <view class="image-container">
        <image 
          class="venue-image" 
          src="{{item.image}}"
          mode="aspectFill"
          lazy-load="true"
        />
        <view class="category-tag {{item.category}}">
          <text class="tag-text">{{getCategoryText(item.category)}}</text>
        </view>
        <view class="favorite-badge">
          <text class="iconfont icon-collect-filled"></text>
        </view>
      </view>
      
      <!-- 场馆信息 -->
      <view class="venue-info">
        <view class="venue-header">
          <view class="venue-name">{{item.name}}</view>
        </view>
        
        <view class="rating-container">
          <view class="stars">
            <text 
              wx:for="{{5}}" 
              wx:key="index"
              class="star {{index < item.rating ? 'active' : ''}}"
            >★</text>
          </view>
          <text class="rating-text">{{item.rating}}</text>
          <text class="review-count">({{item.reviewCount}}条)</text>
        </view>
        
        <view class="address-container">
          <text class="iconfont icon-location"></text>
          <text class="address-text">{{item.address}}</text>
        </view>
        
        <view class="price-container">
          <text class="price-prefix">人均:</text>
          <text class="price-value">¥{{item.price}}</text>
          <text class="price-suffix">/人</text>
        </view>
        
        <view class="features-container">
          <view 
            wx:for="{{item.features}}" 
            wx:key="index"
            class="feature-tag"
          >
            <text class="feature-text">{{item}}</text>
          </view>
        </view>
      </view>
      
      <!-- 操作按钮 -->
      <view class="action-buttons">
        <button 
          class="navigate-btn"
          bindtap="navigateToVenue"
          data-id="{{item.venueId}}"
          catchtap="true"
          hover-class="navigate-btn-hover"
        >
          <text class="iconfont icon-navigate"></text>
          <text class="btn-text">导航</text>
        </button>
        <button 
          class="collect-btn"
          bindtap="onCancelCollect"
          data-id="{{item.venueId}}"
          catchtap="true"
          hover-class="collect-btn-hover"
        >
          <text class="iconfont icon-collect-filled"></text>
          <text class="btn-text">取消</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && venueList.length === 0}}" class="empty-state">
    <view class="empty-icon">
      <text class="iconfont icon-empty-collection"></text>
    </view>
    <text class="empty-title">暂无收藏的场馆</text>
    <text class="empty-subtitle">去发现更多精彩场馆吧</text>
    <button class="go-browse-btn" bindtap="goBrowse" hover-class="go-browse-btn-hover">
      <text class="btn-text">去浏览</text>
    </button>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{hasMore && !loading}}" class="load-more" bindtap="loadMore">
    <text class="load-more-text">加载更多</text>
  </view>
</view>