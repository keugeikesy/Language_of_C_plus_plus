<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-title">编辑个人资料</view>
    <view class="save-btn" bindtap="onSave">保存</view>
  </view>

  <!-- 表单内容 -->
  <view class="form-content">
    <!-- 头像上传 -->
    <view class="form-item">
      <view class="label">头像</view>
      <view class="avatar-upload">
        <image 
          class="avatar-image" 
          src="{{userInfo.avatar}}"
          mode="aspectFill"
        />
        <view class="upload-btn" bindtap="onChooseAvatar">
          <text class="upload-text">更换头像</text>
        </view>
      </view>
    </view>

    <!-- 昵称 -->
    <view class="form-item">
      <view class="label">昵称</view>
      <input 
        class="input-field" 
        placeholder="请输入昵称" 
        value="{{userInfo.nickname}}"
        bindinput="onNicknameChange"
        maxlength="20"
      />
    </view>

    <!-- 性别 -->
    <view class="form-item">
      <view class="label">性别</view>
      <picker 
        class="picker-field" 
        range="{{genderOptions}}" 
        range-key="label"
        value="{{genderIndex}}"
        bindchange="onGenderChange"
      >
        <view class="picker-text">
          {{genderOptions[genderIndex].label}}
        </view>
      </picker>
    </view>

    <!-- 手机号 -->
    <view class="form-item">
      <view class="label">手机号</view>
      <input 
        class="input-field" 
        placeholder="请输入手机号" 
        value="{{userInfo.phone}}"
        bindinput="onPhoneChange"
        type="number"
        maxlength="11"
      />
    </view>

    <!-- 个人简介 -->
    <view class="form-item">
      <view class="label">个人简介</view>
      <textarea 
        class="textarea-field" 
        placeholder="请输入个人简介" 
        value="{{userInfo.introduction}}"
        bindinput="onIntroductionChange"
        maxlength="100"
        placeholder-style="color: #999;"
      />
    </view>
  </view>
</view>